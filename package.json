{
  "name": "next-gamifikasi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5174",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build nextjs-dev",
    "docker:dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:prod": "docker compose up --build -d",
    "docker:prod:down": "docker compose down",
    "docker:migrate": "docker compose --profile seed run --rm db-seed sh -c \"npx prisma migrate deploy\"",
    "docker:seed": "docker compose --profile seed run --rm db-seed",
    "docker:backup": "bash scripts/docker-db-backup.sh",
    "docker:import": "bash scripts/docker-db-import.sh",
    "build": "next build",
    "start": "next start -p 5174",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:unipda-faq": "tsx prisma/seed/run-unipda-faq-import.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
