# =============================================================================
# Next-Gamifikasi Environment Variables
# =============================================================================

# MySQL
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=gamifikasi
MYSQL_USER=gamifikasi
MYSQL_PASSWORD=changeme_user

DATABASE_URL=mysql://gamifikasi:changeme_user@mysql:3306/gamifikasi

# Auth.js v5 (primary)
AUTH_SECRET=generate-a-long-random-secret
AUTH_URL=http://localhost:5174
AUTH_TRUST_HOST=true

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Legacy aliases (optional)
NEXTAUTH_SECRET=generate-a-long-random-secret
NEXTAUTH_URL=http://localhost:5174

# Traefik reverse proxy (optional — Hostinger Traefik uses network_mode: host)
TRAEFIK_HOST=gamifikasi.universitaspgridelta.ac.id
# After DNS works, set AUTH_URL / NEXTAUTH_URL to https://${TRAEFIK_HOST}

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
# How long the model stays loaded after each request (Ollama default: 5m). Use -1 to keep loaded.
OLLAMA_KEEP_ALIVE=30m

# Encrypts recoverable API token secrets at rest (falls back to AUTH_SECRET)
# API_TOKEN_ENCRYPTION_KEY=generate-another-long-random-secret
