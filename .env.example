# =============================================================================
# Next-Gamifikasi Environment Variables
# =============================================================================

# MySQL
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=gamifikasi
MYSQL_USER=gamifikasi
MYSQL_PASSWORD=changeme_user

DATABASE_URL=mysql://gamifikasi:changeme_user@mysql:3306/gamifikasi

# Auth.js v5 (primary) — production: use https://deeptest.universitaspgridelta.ac.id
AUTH_SECRET=generate-a-long-random-secret
AUTH_URL=https://deeptest.universitaspgridelta.ac.id
AUTH_TRUST_HOST=true

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Legacy aliases (optional)
NEXTAUTH_SECRET=generate-a-long-random-secret
NEXTAUTH_URL=https://deeptest.universitaspgridelta.ac.id

# Traefik reverse proxy (Hostinger Traefik uses network_mode: host)
TRAEFIK_HOST=deeptest.universitaspgridelta.ac.id

# Ollama
# Ollama — qwen2.5:3b is default; on CPU VPS try qwen2.5:1.5b for faster replies
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
# CPU threads for inference (set to VPS vCPU count, e.g. 4)
OLLAMA_NUM_THREADS=4
# How long the model stays loaded after each request (Ollama default: 5m).
# Use -1 to keep the model loaded indefinitely (sent as JSON number to Ollama API).
OLLAMA_KEEP_ALIVE=-1

# Encrypts recoverable API token secrets at rest (falls back to AUTH_SECRET)
# API_TOKEN_ENCRYPTION_KEY=generate-another-long-random-secret
